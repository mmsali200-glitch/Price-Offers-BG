# ==================================================
# BG Quotes — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.
#
# IMPORTANT: do NOT wrap values in quotes. Next.js keeps the
# quotes as part of the value, so `KEY="abc"` becomes `"abc"`
# (with the quote characters) instead of `abc`.
# ==================================================

# ── Supabase ──────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# anon / publishable key — safe to expose in the browser.
# New format: sb_publishable_...   Legacy format: eyJhbGci...
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# service_role / secret key — SERVER ONLY, never expose to the client.
# New format: sb_secret_...        Legacy format: eyJhbGci... (~220 chars)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Claude (Anthropic) ────────────────────────────
# Create at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Default model — Sonnet 4.6 (balance of quality + cost)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Resend (Email) ────────────────────────────────
# Create at https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=quotes@bg-tc.com
RESEND_FROM_NAME=Business Gate Quotes

# ── App ───────────────────────────────────────────
# The public URL of the app (used in magic links sent to clients)
NEXT_PUBLIC_APP_URL=http://localhost:3000
